# ============================================================
# Astral App — Variables de entorno del backend
# Copiar este archivo como .env y rellenar los valores
# ============================================================

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=popa
DB_PASSWORD=[CENSURADO]
DB_NAME=astralapp

# JWT — Usar una cadena aleatoria larga y segura
JWT_SECRET=[CENSURADO]

# App
PORT=3000
NODE_ENV=production

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Rutas de volúmenes
VOLUMES_PATH=/var/lib/astralapp/volumes

# RCON — Contraseña para comandos de Minecraft
RCON_PASSWORD=[CENSURADO]

# SMTP — Configuración de Gmail para el formulario de contacto
SMTP_USER=[CENSURADO]@gmail.com
SMTP_PASS=[CENSURADO]
SMTP_TO=[CENSURADO]@gmail.com
